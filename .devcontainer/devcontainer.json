// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Python 3",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",
	"features": {
		"ghcr.io/devcontainers/features/nvidia-cuda:3": {},
		"ghcr.io/iterative/features/nvtop:1": {},
		"ghcr.io/dhoeric/features/opa:1": {},
		"ghcr.io/stu-bell/devcontainer-features/cursor-cli:0": {},
		"ghcr.io/stu-bell/devcontainer-features/open-code:0": {},
		"ghcr.io/natescherer/devcontainers-custom-features/powershell-resources:1": {},
		"ghcr.io/jungaretti/features/make:1": {},
		"ghcr.io/jsburckhardt/devcontainer-features/opencode:1": {},
		"ghcr.io/lentzi90/features/yamlfmt:0": {},
		"ghcr.io/eliises/devcontainer-features/devcontainers-cli:1": {},
		"ghcr.io/wxw-matt/devcontainer-features/command_runner:0": {},
		"ghcr.io/devcontainers-community/npm-features/typescript:1": {},
		"ghcr.io/schlich/devcontainer-features/playwright:0": {},
		"ghcr.io/audacioustux/devcontainers/bun:1": {},
		"ghcr.io/prulloac/devcontainer-features/ollama:1": {},
		"ghcr.io/duduribeiro/devcontainer-features/tmux:1": {},
		"ghcr.io/gvatsal60/dev-container-features/pre-commit:1": {},
		"ghcr.io/devcontainers-extra/features/bash-command:1": {},
		"ghcr.io/devcontainers-extra/features/npm-packages:1": {},
		"ghcr.io/devcontainers-extra/features/opa:1": {},
		"ghcr.io/devcontainers-extra/features/opencode:1": {},
		"ghcr.io/devcontainers-extra/features/projen:1": {},
		"ghcr.io/devcontainers-extra/features/tooljet-cli:1": {},
		"ghcr.io/devcontainers-extra/features/vercel-pkg:1": {},
		"ghcr.io/devcontainers-extra/features/vscode-cli:1": {},
		"ghcr.io/devcontainers-extra/features/vscode-server:1": {},
		"ghcr.io/devcontainers-extra/features/youtube-dl:2": {},
		"ghcr.io/devcontainer-community/devcontainer-features/btop:1": {},
		"ghcr.io/devcontainer-community/devcontainer-features/opencode.ai:1": {},
		"ghcr.io/jajera/features/zip:1": {},
		"ghcr.io/pirpedro/features/dev-gadgets:1": {},
		"ghcr.io/rails/devcontainer/features/activestorage:1": {},
		"ghcr.io/devcontainer-config/features/dot-config:4": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python"
			]
		}
	}

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "pip3 install --user -r requirements.txt",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
